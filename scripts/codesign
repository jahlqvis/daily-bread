#!/bin/bash

set -euo pipefail

target=""
for (( idx=$#; idx>=1; idx-- )); do
  arg="${!idx}"
  if [[ "$arg" != -* ]]; then
    target="$arg"
    break
  fi
done

if [[ -n "$target" && -e "$target" ]]; then
  /usr/bin/xattr -cr "$target" >/dev/null 2>&1 || true
  /usr/bin/xattr -cr "$(dirname "$target")" >/dev/null 2>&1 || true
fi

attempt=1
max_attempts=5

while [[ "$attempt" -le "$max_attempts" ]]; do
  output_file="$(mktemp)"
  set +e
  /usr/bin/codesign "$@" >"$output_file" 2>&1
  status=$?
  set -e

  if [[ "$status" -eq 0 ]]; then
    cat "$output_file"
    rm -f "$output_file"
    exit 0
  fi

  if grep -q "resource fork, Finder information, or similar detritus not allowed" "$output_file"; then
    if [[ -n "$target" && -e "$target" ]]; then
      /usr/bin/xattr -cr "$target" >/dev/null 2>&1 || true
      /usr/bin/xattr -cr "$(dirname "$target")" >/dev/null 2>&1 || true
    fi

    if [[ "$attempt" -lt "$max_attempts" ]]; then
      rm -f "$output_file"
      attempt=$((attempt + 1))
      sleep 1
      continue
    fi
  fi

  cat "$output_file"
  rm -f "$output_file"
  exit "$status"
done

exit 1
